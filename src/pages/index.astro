---
const title = 'Chiu20060726 | Portfolio';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&family=Poppins:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #09090b;
        --bg-accent: #18181b;
        --card: rgba(24, 24, 27, 0.4);
        --card-hover: rgba(39, 39, 42, 0.6);
        --card-border: rgba(255, 255, 255, 0.1);
        --text: #f8fafc;
        --muted: #94a3b8;
        --accent: #8b5cf6;
        --accent-dark: #c4b5fd;
        --accent-soft: rgba(139, 92, 246, 0.2);
        --highlight: #2dd4bf;
        --shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
        --shadow-glow: 0 0 20px rgba(139, 92, 246, 0.3);
        --radius-lg: 24px;
        --radius-md: 16px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Noto Sans", "Poppins", sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--bg);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--accent-soft);
        border-radius: 10px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--accent);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .gradient-text {
        background: linear-gradient(135deg, #a78bfa 0%, #2dd4bf 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      #three-root {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
      }

      #three-root canvas {
        width: 100%;
        height: 100%;
        display: block;
      }

      /* Scroll Reveal Classes */
      .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s ease-out, transform 0.8s ease-out, box-shadow 0.3s ease, border-color 0.3s ease;
      }
      .reveal.active {
        opacity: 1;
        transform: translateY(0);
      }

      /* Vertical Single Column Layout */
      .page {
        position: relative;
        z-index: 1;
        max-width: 800px; /* Narrower width for vertical layout */
        margin: 0 auto;
        padding: 32px 24px 80px;
        display: flex;
        flex-direction: column;
        gap: 32px;
      }

      .top-nav {
        display: flex;
        align-items: center;
        flex-direction: column; /* Centered nav */
        gap: 16px;
        padding: 20px 32px;
        background: var(--card);
        backdrop-filter: blur(20px);
        border: 1px solid var(--card-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        text-align: center;
      }

      .logo {
        font-family: "Poppins", sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
      }

      .nav-links {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        justify-content: center;
        font-size: 0.95rem;
        color: var(--text);
      }

      .nav-links a {
        padding: 6px 16px;
        border-radius: 999px;
        transition: all 0.3s ease;
      }

      .nav-links a:hover {
        background: var(--accent-soft);
        color: var(--accent-dark);
        box-shadow: var(--shadow-glow);
      }

      .hero {
        display: flex;
        flex-direction: column;
        gap: 24px;
      }

      .card-base {
        background: var(--card);
        border-radius: var(--radius-lg);
        padding: 40px 32px;
        box-shadow: var(--shadow);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 20px;
        border: 1px solid var(--card-border);
        backdrop-filter: blur(20px);
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
      }

      .card-base:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-glow);
        border-color: rgba(139, 92, 246, 0.4);
      }

      .hero-card h1 {
        font-size: clamp(2rem, 3vw, 3rem);
        margin: 0;
        font-family: "Poppins", sans-serif;
      }

      .hero-card p {
        margin: 0;
        color: var(--muted);
        max-width: 600px;
      }

      .hero-meta {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
      }

      .pill {
        background: var(--accent-soft);
        color: var(--accent-dark);
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 600;
        border: 1px solid rgba(139, 92, 246, 0.3);
      }

      @keyframes pulse-glow {
        0% { box-shadow: 0 0 15px rgba(139, 92, 246, 0.4); }
        50% { box-shadow: 0 0 35px rgba(139, 92, 246, 0.8); }
        100% { box-shadow: 0 0 15px rgba(139, 92, 246, 0.4); }
      }

      .avatar {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent) 0%, #2dd4bf 100%);
        display: grid;
        place-items: center;
        color: #fff;
        font-size: 3rem;
        font-weight: 700;
        font-family: "Poppins", sans-serif;
        letter-spacing: 1px;
        animation: pulse-glow 4s infinite;
        border: 4px solid rgba(255, 255, 255, 0.1);
        margin-bottom: 8px;
      }

      .section h2 {
        margin: 0 0 8px 0;
        font-family: "Poppins", sans-serif;
        font-size: 1.8rem;
      }

      .section p {
        margin: 0;
        color: var(--muted);
        max-width: 600px;
        line-height: 1.8;
      }

      .experience-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin: 0;
        padding: 0;
        list-style: none;
        width: 100%;
      }

      .experience-item {
        padding: 20px;
        border-radius: var(--radius-md);
        background: rgba(24, 24, 27, 0.5);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 8px;
        border: 1px solid var(--card-border);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .experience-item:hover {
        transform: translateY(-3px);
        background: var(--card-hover);
        box-shadow: 0 8px 20px rgba(139, 92, 246, 0.2);
        border-color: rgba(139, 92, 246, 0.3);
      }

      .experience-item span {
        font-weight: 600;
        color: var(--accent-dark);
        font-size: 1.1rem;
      }

      .skills-grid {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
      }

      .skill-card {
        background: rgba(24, 24, 27, 0.5);
        border-radius: var(--radius-md);
        padding: 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 16px;
        border: 1px solid var(--card-border);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }

      .skill-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-glow);
        background: var(--card-hover);
      }

      .skill-card h3 {
        margin: 0;
        font-size: 1.2rem;
        color: var(--accent-dark);
      }

      .skill-list {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
      }

      .chip {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--text);
        padding: 8px 16px;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.3s ease;
      }

      .chip:hover {
        background: var(--accent-soft);
        border-color: var(--accent);
        color: #fff;
        transform: scale(1.05);
      }

      .club-grid {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
      }

      .club-card {
        background: rgba(24, 24, 27, 0.5);
        border-radius: var(--radius-md);
        padding: 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 12px;
        border: 1px solid var(--card-border);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }

      .club-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-glow);
        background: var(--card-hover);
      }

      .club-card h3 {
        margin: 0;
        font-size: 1.2rem;
        color: var(--accent-dark);
      }

      .club-card ul {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 8px;
        color: var(--muted);
      }

      .footer {
        text-align: center;
        color: var(--muted);
        font-size: 0.9rem;
        padding-top: 20px;
      }

      /* Typewriter cursor effect */
      .typewriter-cursor::after {
        content: '|';
        animation: blink 1s step-end infinite;
        color: var(--highlight);
        font-weight: bold;
      }

      @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }

      @media (max-width: 720px) {
        .card-base {
          padding: 32px 20px;
        }

        .avatar {
          width: 110px;
          height: 110px;
          font-size: 2.2rem;
        }
      }
    </style>
  </head>
  <body>
    <div id="three-root" aria-hidden="true"></div>
    <div class="page">
      <nav class="top-nav reveal">
        <div class="logo gradient-text">Chiu20060726</div>
        <div class="nav-links">
          <a href="#about">About</a>
          <a href="#experience">Experience</a>
          <a href="#skills">Skills</a>
          <a href="#clubs">Clubs</a>
        </div>
      </nav>

      <section class="hero">
        <div class="card-base profile-card reveal">
          <div class="avatar">CH</div>
          <h2 class="gradient-text" style="margin: 0; font-family: 'Poppins', sans-serif; font-size: 2rem;">Chiu20060726</h2>
          <p style="margin: 0; color: var(--muted);">
            High school diploma from Taipei Municipal Zhong-zheng Senior High School.
          </p>
          <p style="margin: 0; color: var(--muted); max-width: 500px;">
            Currently exploring <span class="gradient-text" style="font-weight: 600;">cloud computing</span>,
            <span class="gradient-text" style="font-weight: 600;">wireless communication</span>, and system-level problem
            solving<span class="typewriter-cursor"></span>
          </p>
        </div>

        <div class="card-base hero-card reveal">
          <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
            <p class="pill">CSIE</p>
            <p class="pill" style="border-color: rgba(45, 212, 191, 0.3); color: var(--highlight); background: rgba(45, 212, 191, 0.1);">National Chi Nan University</p>
          </div>
          <h1>About Me</h1>
          <p>
            A student currently studying CSIE at National Chi Nan University, with a passion for
            building full-stack experiences and infrastructure systems.
          </p>
          <div class="hero-meta">
            <span class="pill">Full-Stack &amp; Web3</span>
            <span class="pill">Networking &amp; Cloud</span>
            <span class="pill">Hardware &amp; Firmware</span>
          </div>
        </div>
      </section>

      <section id="about" class="card-base section reveal">
        <h2 class="gradient-text">Snapshot</h2>
        <p>
          Driven by curiosity in computer science and engineering, I enjoy merging software with
          real-world systems. From backend services to routers and firmware, I love turning complex
          infrastructure into reliable experiences.
        </p>
      </section>

      <section id="experience" class="card-base section reveal">
        <h2 class="gradient-text">Experience</h2>
        <ul class="experience-list">
          <li class="experience-item">
            <span>President</span> 
            <div>24th Student Association of CSIE, NCNU</div>
          </li>
          <li class="experience-item">
            <span>Group Leader</span> 
            <div>NCNU ACM Student Chapter</div>
          </li>
          <li class="experience-item">
            <span>Mayor's Award</span> 
            <div>Graduation Students (112th Academic Year, Taipei City)</div>
          </li>
          <li class="experience-item">
            <span>Speaker</span> 
            <div>SITCON 2024</div>
          </li>
          <li class="experience-item">
            <span>3rd Prize</span> 
            <div>2024 TISF Computer Science (No. 190020)</div>
          </li>
          <li class="experience-item">
            <span>Vice-President</span> 
            <div>Information Club, ZZSH</div>
          </li>
        </ul>
      </section>

      <section id="skills" class="card-base section reveal">
        <h2 class="gradient-text">Skills</h2>
        <div class="skills-grid">
          <div class="skill-card">
            <h3>Coding</h3>
            <div class="skill-list">
              <span class="chip">C/C++</span>
              <span class="chip">PHP</span>
              <span class="chip">Python</span>
              <span class="chip">JavaScript</span>
            </div>
          </div>
          <div class="skill-card">
            <h3>Web</h3>
            <div class="skill-list">
              <span class="chip">Full-Stack</span>
              <span class="chip">Back-end</span>
              <span class="chip">Web3 / Blockchain</span>
            </div>
          </div>
          <div class="skill-card">
            <h3>Internet</h3>
            <div class="skill-list">
              <span class="chip">Router / Switch (Juniper)</span>
              <span class="chip">Firewall Config</span>
              <span class="chip">DNS / DHCP</span>
              <span class="chip">Server Ops (Unix/Windows)</span>
              <span class="chip">Cloud (GCP/AWS/OCI)</span>
              <span class="chip">Git</span>
            </div>
          </div>
          <div class="skill-card">
            <h3>Wireless</h3>
            <div class="skill-list">
              <span class="chip">WiFi</span>
              <span class="chip">BLE</span>
              <span class="chip">LoRa</span>
            </div>
          </div>
          <div class="skill-card">
            <h3>Hardware / Firmware</h3>
            <div class="skill-list">
              <span class="chip">PCB Design</span>
              <span class="chip">Circuit Design</span>
              <span class="chip">HDL (Verilog)</span>
            </div>
          </div>
        </div>
      </section>

      <section id="clubs" class="card-base section reveal">
        <h2 class="gradient-text">School Clubs</h2>
        <div class="club-grid">
          <div class="club-card">
            <h3>University</h3>
            <ul>
              <li>NCNU ACM Student Chapter</li>
              <li>Student Association of CSIE, NCNU</li>
              <li>Photography Club</li>
              <li>ACGN Club</li>
              <li>GDSC NCNU</li>
            </ul>
          </div>
          <div class="club-card">
            <h3>High School</h3>
            <ul>
              <li>Information Club</li>
            </ul>
          </div>
        </div>
      </section>

      <footer class="footer reveal">© 2026 CSC</footer>
    </div>
    
    <script>
      import '../scripts/three-background.js';
      // Intersection Observer for scroll animations
      document.addEventListener('DOMContentLoaded', () => {
        const reveals = document.querySelectorAll('.reveal');
        
        const revealOptions = {
          threshold: 0.1,
          rootMargin: "0px 0px -50px 0px"
        };
        
        const revealOnScroll = new IntersectionObserver(function(entries, observer) {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('active');
            // Stop observing once revealed
            observer.unobserve(entry.target);
          });
        }, revealOptions);
        
        reveals.forEach(reveal => {
          revealOnScroll.observe(reveal);
        });
      });
    </script>
  </body>
</html>
