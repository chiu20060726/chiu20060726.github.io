---
const title = 'Chiu20060726 | 個人檔案';
---
<!DOCTYPE html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Chiu20060726 的個人作品集網站 — 資工系學生，專注於全端開發、雲端運算與網路系統。" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&family=Poppins:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --bg: #09090b;
        --bg-accent: #18181b;
        --card: rgba(24, 24, 27, 0.4);
        --card-hover: rgba(39, 39, 42, 0.6);
        --card-border: rgba(255, 255, 255, 0.1);
        --text: #f8fafc;
        --muted: #94a3b8;
        --accent: #8b5cf6;
        --accent-dark: #c4b5fd;
        --accent-soft: rgba(139, 92, 246, 0.2);
        --highlight: #2dd4bf;
        --shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.5);
        --shadow-glow: 0 0 20px rgba(139, 92, 246, 0.3);
        --radius-lg: 24px;
        --radius-md: 16px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Noto Sans TC", "Noto Sans", "Poppins", sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--bg);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--accent-soft);
        border-radius: 10px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--accent);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .gradient-text {
        background: linear-gradient(135deg, #a78bfa 0%, #2dd4bf 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      #three-root {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
      }

      #three-root canvas {
        width: 100%;
        height: 100%;
        display: block;
      }

      /* Scroll Reveal Classes */
      .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s ease-out, transform 0.8s ease-out, box-shadow 0.3s ease, border-color 0.3s ease;
      }
      .reveal.active {
        opacity: 1;
        transform: translateY(0);
      }

      /* Vertical Single Column Layout */
      .page {
        position: relative;
        z-index: 1;
        max-width: 800px; /* Narrower width for vertical layout */
        margin: 0 auto;
        padding: 32px 24px 80px;
        display: flex;
        flex-direction: column;
        gap: 32px;
      }

      .top-nav {
        display: flex;
        align-items: center;
        flex-direction: column; /* Centered nav */
        gap: 16px;
        padding: 20px 32px;
        background: var(--card);
        backdrop-filter: blur(20px);
        border: 1px solid var(--card-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow);
        text-align: center;
      }

      .nav-top-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        width: 100%;
        flex-wrap: wrap;
      }

      .logo {
        font-family: "Poppins", sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: 0.8px;
        text-transform: uppercase;
      }

      .lang-switch {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--accent-soft);
        border: 1px solid rgba(139, 92, 246, 0.3);
        color: var(--accent-dark);
        padding: 5px 14px;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 600;
        transition: all 0.3s ease;
        cursor: pointer;
      }

      .lang-switch:hover {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
        transform: scale(1.05);
        box-shadow: var(--shadow-glow);
      }

      .lang-switch svg {
        width: 14px;
        height: 14px;
        fill: currentColor;
      }

      .nav-links {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        justify-content: center;
        font-size: 0.95rem;
        color: var(--text);
      }

      .nav-links a {
        padding: 6px 16px;
        border-radius: 999px;
        transition: all 0.3s ease;
      }

      .nav-links a:hover {
        background: var(--accent-soft);
        color: var(--accent-dark);
        box-shadow: var(--shadow-glow);
      }

      .hero {
        display: flex;
        flex-direction: column;
        gap: 24px;
      }

      .card-base {
        background: var(--card);
        border-radius: var(--radius-lg);
        padding: 40px 32px;
        box-shadow: var(--shadow);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 20px;
        border: 1px solid var(--card-border);
        backdrop-filter: blur(20px);
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
      }

      .card-base:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-glow);
        border-color: rgba(139, 92, 246, 0.4);
      }

      .hero-card h1 {
        font-size: clamp(2rem, 3vw, 3rem);
        margin: 0;
        font-family: "Poppins", sans-serif;
      }

      .hero-card p {
        margin: 0;
        color: var(--muted);
        max-width: 600px;
      }

      .hero-meta {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
      }

      .pill {
        background: var(--accent-soft);
        color: var(--accent-dark);
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 600;
        border: 1px solid rgba(139, 92, 246, 0.3);
      }

      @keyframes pulse-glow {
        0% { box-shadow: 0 0 15px rgba(139, 92, 246, 0.4); }
        50% { box-shadow: 0 0 35px rgba(139, 92, 246, 0.8); }
        100% { box-shadow: 0 0 15px rgba(139, 92, 246, 0.4); }
      }

      .avatar {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--accent) 0%, #2dd4bf 100%);
        animation: pulse-glow 4s infinite;
        border: 4px solid rgba(255, 255, 255, 0.1);
        margin-bottom: 8px;
        overflow: hidden;
        display: grid;
        place-items: center;
      }

      .avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
      }

      .section h2 {
        margin: 0 0 8px 0;
        font-family: "Poppins", sans-serif;
        font-size: 1.8rem;
      }

      .section p {
        margin: 0;
        color: var(--muted);
        max-width: 600px;
        line-height: 1.8;
      }

      .experience-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin: 0;
        padding: 0;
        list-style: none;
        width: 100%;
      }

      .experience-item {
        padding: 20px;
        border-radius: var(--radius-md);
        background: rgba(24, 24, 27, 0.5);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 8px;
        border: 1px solid var(--card-border);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .experience-item:hover {
        transform: translateY(-3px);
        background: var(--card-hover);
        box-shadow: 0 8px 20px rgba(139, 92, 246, 0.2);
        border-color: rgba(139, 92, 246, 0.3);
      }

      .experience-item span {
        font-weight: 600;
        color: var(--accent-dark);
        font-size: 1.1rem;
      }

      .skills-grid {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
      }

      .skill-card {
        background: rgba(24, 24, 27, 0.5);
        border-radius: var(--radius-md);
        padding: 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 16px;
        border: 1px solid var(--card-border);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }

      .skill-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-glow);
        background: var(--card-hover);
      }

      .skill-card h3 {
        margin: 0;
        font-size: 1.2rem;
        color: var(--accent-dark);
      }

      .skill-list {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
      }

      .chip {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--text);
        padding: 8px 16px;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.3s ease;
      }

      .chip:hover {
        background: var(--accent-soft);
        border-color: var(--accent);
        color: #fff;
        transform: scale(1.05);
      }

      .club-grid {
        display: flex;
        flex-direction: column;
        gap: 16px;
        width: 100%;
      }

      .club-card {
        background: rgba(24, 24, 27, 0.5);
        border-radius: var(--radius-md);
        padding: 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 12px;
        border: 1px solid var(--card-border);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }

      .club-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-glow);
        background: var(--card-hover);
      }

      .club-card h3 {
        margin: 0;
        font-size: 1.2rem;
        color: var(--accent-dark);
      }

      .club-card ul {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 8px;
        color: var(--muted);
      }

      .footer {
        text-align: center;
        color: var(--muted);
        font-size: 0.9rem;
        padding-top: 20px;
      }

      .contact-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 16px;
        margin-top: 16px;
      }

      .contact-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--card-border);
        color: var(--text);
        padding: 10px 20px;
        border-radius: 12px;
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.3s ease;
      }

      .contact-btn:hover {
        background: var(--card-hover);
        border-color: var(--accent);
        transform: translateY(-3px);
        box-shadow: var(--shadow-glow);
        color: var(--accent-dark);
      }
      
      .contact-btn svg {
        width: 20px;
        height: 20px;
        fill: currentColor;
      }

      /* Typewriter cursor effect */
      .typewriter-cursor::after {
        content: '|';
        animation: blink 1s step-end infinite;
        color: var(--highlight);
        font-weight: bold;
      }

      @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }

      @media (max-width: 720px) {
        .card-base {
          padding: 32px 20px;
        }

        .avatar {
          width: 110px;
          height: 110px;
          font-size: 2.2rem;
        }
      }
    </style>
  </head>
  <body>
    <div id="three-root" aria-hidden="true"></div>
    <div class="page">
      <nav class="top-nav reveal">
        <div class="nav-top-row">
          <div class="logo gradient-text">Ching Shun Chiu</div>
          <a href="/" class="lang-switch">
            <svg viewBox="0 0 24 24"><path d="M12.87 15.07l-2.54-2.51.03-.03A17.52 17.52 0 0014.07 6H17V4h-7V2H8v2H1v1.99h11.17C11.5 7.92 10.44 9.75 9 11.35 8.07 10.32 7.3 9.19 6.69 8h-2c.73 1.63 1.73 3.17 2.98 4.56l-5.09 5.02L4 19l5-5 3.11 3.11.76-2.04zM18.5 10h-2L12 22h2l1.12-3h4.75L21 22h2l-4.5-12zm-2.62 7l1.62-4.33L19.12 17h-3.24z"/></svg>
            EN
          </a>
        </div>
        <div class="nav-links">
          <a href="#about">關於</a>
          <a href="#experience">經歷</a>
          <a href="#skills">技能</a>
          <a href="#clubs">社團</a>
          <a href="#contact">聯絡</a>
        </div>
      </nav>

      <section class="hero">
        <div class="card-base profile-card reveal">
          <div class="avatar"><img src="https://gravatar.com/avatar/9a8443a770fef6f9d71469560274ff53?s=280" alt="邱靖舜" loading="eager" /></div>
          <h2 class="gradient-text" style="margin: 0; font-family: 'Poppins', sans-serif; font-size: 2rem;">邱靖舜</h2>
          <p style="margin: 0; color: var(--muted);">
            畢業於臺北市立中正高級中學。
          </p>
          <p style="margin: 0; color: var(--muted); max-width: 500px;">
            目前正在探索<span class="gradient-text" style="font-weight: 600;">雲端運算</span>、<span class="gradient-text" style="font-weight: 600;">無線通訊</span>，以及系統層級的問題解決<span class="typewriter-cursor"></span>
          </p>
        </div>

        <div class="card-base hero-card reveal">
          <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
            <p class="pill">資訊工程學系</p>
            <p class="pill" style="border-color: rgba(45, 212, 191, 0.3); color: var(--highlight); background: rgba(45, 212, 191, 0.1);">國立暨南國際大學</p>
          </div>
          <h1>關於我</h1>
          <p>
            目前就讀於國立暨南國際大學資訊工程學系，對全端開發與基礎設施系統有著濃厚的興趣。
          </p>
          <div class="hero-meta">
            <span class="pill">全端 &amp; Web3</span>
            <span class="pill">網路 &amp; 雲端</span>
            <span class="pill">硬體 &amp; 韌體</span>
          </div>
        </div>
      </section>

      <section id="about" class="card-base section reveal">
        <h2 class="gradient-text">簡介</h2>
        <p>
          出於對資訊科學與工程的好奇心驅動，我喜歡將軟體與真實世界系統結合。
          從後端服務到路由器與韌體，我熱愛將複雜的基礎設施轉化為可靠的使用體驗。
        </p>
      </section>

      <section id="experience" class="card-base section reveal">
        <h2 class="gradient-text">經歷</h2>
        <ul class="experience-list">
          <li class="experience-item">
            <span>會長</span> 
            <div>暨大資工系第 24 屆系學會</div>
          </li>
          <li class="experience-item">
            <span>組長</span> 
            <div>暨大 ACM 學生分會</div>
          </li>
          <li class="experience-item">
            <span>市長獎</span> 
            <div>112 學年度臺北市畢業生</div>
          </li>
          <li class="experience-item">
            <span>講者</span> 
            <div>SITCON 2024</div>
          </li>
          <li class="experience-item">
            <span>佳作</span> 
            <div>2024 TISF 電腦與資訊學科（No. 190020）</div>
          </li>
          <li class="experience-item">
            <span>副社長</span> 
            <div>中正高中 資訊研究社</div>
          </li>
        </ul>
      </section>

      <section id="skills" class="card-base section reveal">
        <h2 class="gradient-text">技能</h2>
        <div class="skills-grid">
          <div class="skill-card">
            <h3>程式語言</h3>
            <div class="skill-list">
              <span class="chip">C/C++</span>
              <span class="chip">PHP</span>
              <span class="chip">Python</span>
              <span class="chip">JavaScript</span>
            </div>
          </div>
          <div class="skill-card">
            <h3>網頁開發</h3>
            <div class="skill-list">
              <span class="chip">全端開發</span>
              <span class="chip">後端</span>
              <span class="chip">Web3 / 區塊鏈</span>
            </div>
          </div>
          <div class="skill-card">
            <h3>網路</h3>
            <div class="skill-list">
              <span class="chip">路由器 / 交換器 (Juniper)</span>
              <span class="chip">防火牆設定</span>
              <span class="chip">DNS / DHCP</span>
              <span class="chip">伺服器管理 (Unix/Windows)</span>
              <span class="chip">雲端 (GCP/AWS/OCI)</span>
              <span class="chip">Git</span>
            </div>
          </div>
          <div class="skill-card">
            <h3>無線通訊</h3>
            <div class="skill-list">
              <span class="chip">WiFi</span>
              <span class="chip">BLE</span>
              <span class="chip">LoRa</span>
            </div>
          </div>
          <div class="skill-card">
            <h3>硬體 / 韌體</h3>
            <div class="skill-list">
              <span class="chip">PCB 設計</span>
              <span class="chip">電路設計</span>
              <span class="chip">HDL (Verilog)</span>
            </div>
          </div>
        </div>
      </section>

      <section id="clubs" class="card-base section reveal">
        <h2 class="gradient-text">社團</h2>
        <div class="club-grid">
          <div class="club-card">
            <h3>大學</h3>
            <ul>
              <li>暨大 ACM 學生分會</li>
              <li>暨大資工系學會</li>
              <li>攝影社</li>
              <li>動漫社</li>
              <li>GDSC NCNU</li>
            </ul>
          </div>
          <div class="club-card">
            <h3>高中</h3>
            <ul>
              <li>資訊社</li>
            </ul>
          </div>
        </div>
      </section>

      <section id="contact" class="card-base section reveal">
        <h2 class="gradient-text">聯絡方式</h2>
        <p>歡迎透過以下平台與我聯繫。</p>
        <div class="contact-links">
          <a href="https://github.com/chiu20060726" target="_blank" class="contact-btn">
            <svg viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="mailto:chiu20060726@gmail.com" target="_blank" class="contact-btn">
            <svg viewBox="0 0 24 24"><path d="M0 3v18h24v-18h-24zm21.518 2l-9.518 7.713-9.518-7.713h19.036zm-19.518 14v-11.817l10 8.104 10-8.104v11.817h-20z"/></svg>
            Email
